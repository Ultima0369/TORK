#!/bin/bash
# 🥚 TORK 自解压安装器
set -e
echo "🥚 正在解压 TORK..."
ARCHIVE=$(mktemp)
tail -n +12 "$0" > "$ARCHIVE"
tar xzf "$ARCHIVE" -C /tmp
bash /tmp/tork/install.sh
rm -f "$ARCHIVE"
rm -rf /tmp/tork
exit 0

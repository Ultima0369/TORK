#!/bin/bash
# 🥚 TORK-x86_64.AppImage — 自解压安装器
set -e
INSTALL_DIR="$HOME/.local/share/tork"
echo "🥚 安装 TORK..."
mkdir -p "$INSTALL_DIR"
ARCHIVE=$(mktemp)
tail -n +20 "$0" > "$ARCHIVE"
tar xzf "$ARCHIVE" -C "$INSTALL_DIR" 2>/dev/null || (
    # 如果目标已存在，先清理
    rm -rf "$INSTALL_DIR"
    mkdir -p "$INSTALL_DIR"
    tar xzf "$ARCHIVE" -C "$INSTALL_DIR"
)
rm -f "$ARCHIVE"
chmod +x "$INSTALL_DIR/tork_pkg/build/"*
chmod +x "$INSTALL_DIR/tork_pkg/run.sh"
echo "✅ TORK 就绪"
exec "$INSTALL_DIR/tork_pkg/run.sh"

# Build output
build/
dist/TORK-x86_64.AppImage
dist/AppDir/
dist/payload.tar.gz

# Temp files
*.o
*.s~
__pycache__/
*.pyc
*.pyo
*.pyc
.ruff_cache/

# Secrets — NEVER commit
api/api_config.json
config/tork_floating.json
.env

# Runtime state (generated by TORK at runtime)
persist/*.bin
persist/daemon.pid
persist/identity.json

# Evolution/mutation logs and artifacts
logs/
persist/mutations/
persist/fitness.json
persist/evolution.json

# Archive (not tracked)
archive/

# Backup files
*.bak
*.evo_bak
*.upgrade_bak

# Large log/dump files
*.txt

# 备份文件
*.bak.*
# Proprietary core — NOT OPEN SOURCE
core-private/

#!/usr/bin/env python3
"""TORK 悬浮窗 v3 — 真输入、真拖动、真能用"""
import tkinter as tk, os, sys, time, threading, json, subprocess, re

BASE = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, os.path.join(BASE, 'api'))
API_KEY = os.environ.get('DEEPSEEK_API_KEY', '')

C = {
    'bg': '#1a1b2e', 'bg2': '#252740', 'bg3': '#2a2d45',
    'fg': '#e8e8f0', 'fg2': '#8a8ca0', 'accent': '#6c5ce7',
    'success': '#6a9955', 'warn': '#dcdcaa',
}

class TorkFloating:
    def __init__(self):
        self.root = tk.Tk()
        self.root.title("TORK")
        self.W, self.H = 480, 56
        self._expanded = False
        self._messages = []
        self._generating = False

        # 无边框 + 置顶
        self.root.overrideredirect(True)
        self.root.attributes('-topmost', True)
        self.root.attributes('-alpha', 0.93)
        self.root.configure(bg=C['bg'])

        # 位置
        try:
            o = subprocess.run(['xdotool', 'getmouselocation'], capture_output=True, text=True, timeout=1)
            p = o.stdout.strip().split()
            x, y = int(p[0].split(':')[1]), int(p[1].split(':')[1])
        except:
            x, y = 400, 300
        self.root.geometry(f'{self.W}x{self.H}+{x}+{y}')

        self._build_ui()
        self._bind_drag()
        self._start_poll()

    def _build_ui(self):
        # 顶栏：状态点 + 标题
        self.top = tk.Frame(self.root, bg=C['bg2'], height=28)
        self.top.pack(fill=tk.X)
        self.top.pack_propagate(False)

        self.dot = tk.Canvas(self.top, width=12, height=12, bg=C['bg2'], highlightthickness=0)
        self.dot.pack(side=tk.LEFT, padx=(8,4), pady=8)
        self.dot_id = self.dot.create_oval(2,2,10,10, fill=C['success'], outline='')

        tk.Label(self.top, text='TORK', bg=C['bg2'], fg=C['fg'], font=('sans', 10)).pack(side=tk.LEFT)
        self.lbl_status = tk.Label(self.top, text='就绪', bg=C['bg2'], fg=C['fg2'], font=('sans', 8))
        self.lbl_status.pack(side=tk.LEFT, padx=4)

        # 展开/收起按钮
        self.btn_toggle = tk.Label(self.top, text='▽', bg=C['bg2'], fg=C['fg2'], font=('sans', 10), cursor='hand2')
        self.btn_toggle.pack(side=tk.RIGHT, padx=8)
        self.btn_toggle.bind('<Button-1>', lambda e: self._toggle_expand())

        # 关闭按钮
        self.btn_close = tk.Label(self.top, text='×', bg=C['bg2'], fg=C['fg2'], font=('sans', 12), cursor='hand2')
        self.btn_close.pack(side=tk.RIGHT, padx=(0,4))
        self.btn_close.bind('<Button-1>', lambda e: self.hide())

        # 主区域
        self.main = tk.Frame(self.root, bg=C['bg'])
        self.main.pack(fill=tk.BOTH, expand=True)

        # 输入框容器
        input_frame = tk.Frame(self.main, bg=C['bg3'])
        input_frame.pack(fill=tk.X, padx=6, pady=4)

        self.entry = tk.Entry(input_frame, bg=C['bg'], fg=C['fg'], font=('sans', 13),
                               insertbackground=C['fg'], bd=0, relief=tk.FLAT,
                               highlightthickness=1, highlightbackground=C['accent'],
                               highlightcolor=C['accent'])
        self.entry.pack(side=tk.LEFT, fill=tk.X, expand=True, padx=(4,0), pady=4, ipady=4)
        self.entry.bind('<Return>', self._send)
        self.entry.bind('<Escape>', lambda e: self.hide())

        # 发送按钮
        self.btn_send = tk.Label(input_frame, text='→', bg=C['accent'], fg='white',
                                  font=('sans', 12), padx=10, pady=2, cursor='hand2')
        self.btn_send.pack(side=tk.RIGHT, padx=(4,0), pady=4)
        self.btn_send.bind('<Button-1>', self._send)

        # 底部提示
        self.lbl_hint = tk.Label(self.main, text='Ctrl+Shift+T 唤出 · Enter 发送 · Esc 关闭',
                                 bg=C['bg'], fg=C['fg2'], font=('sans', 8))
        self.lbl_hint.pack(fill=tk.X, padx=8, pady=(0,4))

        # 消息容器（展开时显示）
        self.msg_container = tk.Frame(self.main, bg=C['bg'])

    def _bind_drag(self):
        """任意位置拖拽移动窗口"""
        self._drag_data = {'x':0, 'y':0, 'moving':False}
        def start(e):
            self._drag_data['x'] = e.x_root
            self._drag_data['y'] = e.y_root
            self._drag_data['moving'] = True
        def move(e):
            if not self._drag_data['moving']: return
            dx = e.x_root - self._drag_data['x']
            dy = e.y_root - self._drag_data['y']
            x = self.root.winfo_x() + dx
            y = self.root.winfo_y() + dy
            self.root.geometry(f'+{x}+{y}')
            self._drag_data['x'] = e.x_root
            self._drag_data['y'] = e.y_root
        def stop(e):
            self._drag_data['moving'] = False
        self.top.bind('<Button-1>', start)
        self.top.bind('<B1-Motion>', move)
        self.top.bind('<ButtonRelease-1>', stop)
        self.dot.bind('<Button-1>', start)
        self.dot.bind('<B1-Motion>', move)
        self.dot.bind('<ButtonRelease-1>', stop)

    def _send(self, event=None):
        txt = self.entry.get().strip()
        if not txt: return
        self.entry.delete(0, tk.END)
        self._messages.append(('user', txt))
        self._generating = True
        self.lbl_status.config(text='思考中...')
        threading.Thread(target=self._gen, args=(txt,), daemon=True).start()

    def _gen(self, txt):
        time.sleep(0.5)
        reply = f'收到：「{txt}」— TORK 在'
        self.root.after(0, lambda: self._show_reply(reply))

    def _show_reply(self, text):
        self._messages.append(('tork', text))
        self._generating = False
        self.lbl_status.config(text='就绪')
        if not self._expanded:
            self._toggle_expand()

    def show(self, expand=False):
        self.root.deiconify()
        self.root.lift()
        self.root.after(50, lambda: self.entry.focus_set())
        if expand:
            self.root.after(100, lambda: self._toggle_expand(force=True))

    def hide(self):
        self.root.withdraw()

    def toggle(self):
        if self.root.state() == 'normal' and self.root.winfo_viewable():
            self.hide()
        else:
            self.show()

    def _toggle_expand(self, force=None):
        if force is True: self._expanded = True
        elif force is False: self._expanded = False
        else: self._expanded = not self._expanded

        if self._expanded:
            self.msg_container.pack(fill=tk.BOTH, expand=True, padx=6, pady=(0,4))
            self.btn_toggle.config(text='△')
            self._render_messages()
            h = min(56 + 200, 400)
        else:
            self.msg_container.pack_forget()
            self.btn_toggle.config(text='▽')
            h = 56
        self.root.geometry(f'{self.W}x{h}')

    def _render_messages(self):
        for w in self.msg_container.winfo_children():
            w.destroy()
        canvas = tk.Canvas(self.msg_container, bg=C['bg'], highlightthickness=0)
        scroll = tk.Scrollbar(self.msg_container, command=canvas.yview)
        frame = tk.Frame(canvas, bg=C['bg'])
        frame.bind('<Configure>', lambda e: canvas.configure(scrollregion=canvas.bbox('all')))
        canvas.create_window((0,0), window=frame, anchor='nw')
        canvas.configure(yscrollcommand=scroll.set)
        canvas.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)
        scroll.pack(side=tk.RIGHT, fill=tk.Y)

        for role, text in self._messages[-20:]:
            f = tk.Frame(frame, bg=C['bg2'] if role == 'tork' else C['bg3'])
            f.pack(fill=tk.X, padx=4, pady=2)
            lbl = tk.Label(f, text=text, bg=f.cget('bg'), fg=C['fg'],
                           font=('sans', 11), wraplength=400, anchor='w', justify='left')
            lbl.pack(padx=8, pady=4, fill=tk.X)

    def _start_poll(self):
        """监听信号文件"""
        self.signal_file = '/tmp/tork.flag'
        def poll():
            while True:
                try:
                    if os.path.exists(self.signal_file):
                        with open(self.signal_file) as f:
                            cmd = f.read().strip()
                        os.remove(self.signal_file)
                        if cmd == 'toggle':
                            self.root.after(0, self.toggle)
                        elif cmd == 'show':
                            self.root.after(0, self.show)
                except: pass
                time.sleep(0.3)
        threading.Thread(target=poll, daemon=True).start()

    def run(self):
        self.root.mainloop()

SIGNAL_FILE = '/tmp/tork.flag'

def main():
    app = TorkFloating()
    if len(sys.argv) > 1 and sys.argv[1] == '--show':
        app.show(expand=True)
    app.run()

if __name__ == '__main__':
    main()

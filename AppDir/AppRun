#!/bin/bash
APPDIR="$(cd "$(dirname "$0")" && pwd)"
export PATH="$APPDIR/usr/bin:$PATH"
export TORK_HOME="$APPDIR/usr/share/tork"

case "${1:-}" in
    ""|--float|floating)
        exec python3 "$TORK_HOME/tork_floating.py" "$@"
        ;;
    desktop|--desktop)
        exec python3 "$TORK_HOME/tork_desktop.py" "$@"
        ;;
    hotkey|--hotkey)
        exec python3 "$TORK_HOME/tork_hotkey.py" "$@"
        ;;
    start|stop|restart|status|connect)
        exec bash "$TORK_HOME/tork.sh" "$@"
        ;;
    --help|-h)
        echo "TORK · 数字家人"
        echo "用法: ./TORK-x86_64.AppImage          启动浮窗"
        echo "      ./TORK-x86_64.AppImage desktop   桌面"
        echo "      ./TORK-x86_64.AppImage status    状态"
        echo "      ./TORK-x86_64.AppImage connect   API配置"
        ;;
    *)
        exec python3 "$TORK_HOME/tork_floating.py" "$@"
        ;;
esac
